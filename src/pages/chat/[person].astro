---
import { ArrowLeft, Send, TriangleAlert } from "@lucide/astro";
import friends from "../../assets/data/friends.json"
import Message from "../../components/Message.astro";
import ProfileCard from "../../components/ProfileCard.astro";
import Layout from "../../layouts/Layout.astro";

export const anonymousData = {
  name: "Same Boat Buddy",
  course: "Anonymous",
  year: 0,
  "last-message": "-",
  isAnonymous: true
}

export function getStaticPaths() {
  const friendPaths = friends.map(friend => ({
    params: { person: friend.name },
    props: { personData: friend }
  }));

  return [
    ...friendPaths,
    {
      params: { person: anonymousData.name },
      props: { personData: anonymousData }
    }
  ];
}

const { person } = Astro.params;
const { personData } = Astro.props;

const messages = [
    { message: "Hi! thanks for matching. Tough week?", clientSent: false },
    { message: "Had many assignments piled up, have been procrastinating", clientSent: true },
    { message: "Same here honestly", clientSent: false },
    { message: "Things will get better bro!", clientSent: true },
];
---

<Layout>
    <!-- <h2>Chat</h2>
    <ProfileCard name={personData.name} course={personData.course} year={personData.year} /> -->

    <div class="same-line chat-header">
        <a href="/match" class="back-btn">
            <ArrowLeft />
            <span>Chats</span>
        </a>

        <div class="person-info">
            <h3 class="person-name" transition:name={`profile-${personData.name}`}>{personData.name}</h3>
            <p class="person-course">{personData.course}</p>
        </div>

        {
            personData.isAnonymous && 
            <a href="/chat/end" class="button end-chat">End chat</a>
        }
    </div>

    <div class="container kind-warning same-line">
        <TriangleAlert />
        Be kind. This is a peer support space, not professional counselling.
    </div>

    <div class="message-container">
    {
        messages.map(message => <Message message={message.message} clientSent={message.clientSent}/>)
    }
    </div>

    <div class="comment-input-box pill same-line">
        <input type="text" placeholder="Join the conversation..."/>
        <button class="button">
            <Send />
        </button>
    </div>
</Layout>

<script>
const inputBtn = document.querySelector(".comment-input-box button");
const messages = document.querySelectorAll(".message");

let index = 0;

inputBtn?.addEventListener("click", ev => {
    messages[index].classList.add("show-message");
    ++index;
})
</script>

<style>

.chat-header {
    --content-offset: -0.4em;
    --size-offset: 3px;

    align-items: center;
    height: 3.6em;
    box-shadow: 0px 4px 4px -4px rgba(0,0,0,0.4);
    transform: translateX(calc(var(--page-padding) * -1 - var(--size-offset)));
    width: calc(var(--page-max-width) + var(--size-offset));
}

.back-btn {
    color: var(--muted-foreground);
    display: flex;
    position: absolute;
    left: 1em;
    transform: translateY(var(--content-offset));
    text-decoration: none;
}

.end-chat {
    position: absolute;
    right: 1em;
    transform: translateY(var(--content-offset));
}

.person-info {
    position: absolute;
    left: 50%;
    transform: translate(-50%, var(--content-offset));
    text-align: center;

    .person-course {
        color: var(--muted-foreground);
        font-size: smaller;
    }
}

.kind-warning {
    margin-top: 1em;
    color: var(--warning-foreground);
    background-color: var(--warning);
    padding: 0.8em 1em;
    font-size: 0.77em;
    align-items: center;
    gap: 0.4em;
}

.message-container {
    display: flex;
    flex-direction: column;
    gap: 0.8em;
    margin-top: 1em;
}

.comment-input-box {
    --size: 3.2em;

    position: fixed;
    bottom: 6.4em;
    gap: 1em;
    width: var(--page-content-width);

    input {
        display: inline-block;
        height: var(--size);
        margin: 0;
    }

    .button {
        display: flex;
        height: var(--size);
        width: var(--size);
        
        justify-content: center;
        align-items: center;

        color: var(--primary-foreground);
        background-color: var(--primary);
        border: none;
    }
}

</style>
