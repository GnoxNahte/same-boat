---
import { ShieldCheck } from "@lucide/astro/icons/index";
import Zones from "../components/Zones.astro";
import Layout from "../layouts/Layout.astro";

// locations for heatmap
const locations = [
{ name: "Library",
    icon: "😴",
    size: 5,
    top: 12,
    left: 18,
    mood: "Tired",
    need: "Quiet Company"
},
{ name: "Canteen",
    icon: "🙂",
    size: 20,
    top: 20,
    left: 62,
    mood: "Okay",
    need: "Just checking in"
},
{ name: "Study Area",
    icon: "😣",
    size: 5,
    top: 52,
    left: 30,
    mood: "Stressed",
    need: "Study buddy"
},
{ name: "Classroom Block",
    icon: "😟",
    size: 30,
    top: 60,
    left: 70,
    mood: "Anxious",
    need: "Encouragement"
},
{ name: "Gym",
    icon: "💪",
    size: 10,
    top: 78,
    left: 45,
    mood: "Motivated",
    need: "Talk buddy"
},
]
---

<Layout>
    <h2>Match</h2>
    <div class="main-focus container">
        <h3>See how your school is feeling today.</h3>
        <p>56 check-ins across campus today. You are not alone in this zone.</p>
    </div>

    <h2>Campus mood map</h2>
    <p class="status">Soft glows show where mood is concentrated. Broad zones only. No exact locations.</p>
    <div class="main-focus container heat-map">
        <div class="container">
        {
            locations.map(location => {
                // let sizeStr = "";
                // if (location.size == 0) sizeStr = "No one here";
                // else if (location.size <= 5) sizeStr = "1 - 5 people";
                // else if (location.size <= 15) sizeStr = "6 - 15 people";
                // else if (location.size <= 30) sizeStr = "16 - 30 people";
                // else  sizeStr = "> 30 people";

                return (
                    <div class="location" style={`top: ${location.top}%; left: ${location.left}%`}>
                        <div class="bg"></div>
                        <div class="icon">
                            <span>{location.icon}</span>
                        </div>
                        <div class="info">
                            <p>{location.name}</p>
                            {/* <p>{sizeStr}</p> */}
                        </div>
                    </div>
                )
            })   
        }
        </div>
        <p><i>"You are not alone in this zone."</i></p>
    </div>

    <h2>Zones today</h2>
    {
        locations.map(location => 
            <Zones name={location.name} icon={location.icon} mood={location.mood} size={location.size} need={location.need} />
        )
    }
    <div class="notice status-info pill">
        <ShieldCheck class='icon'/>
        <span>We only show broad zones, never exact locations or identities.</span>
    </div>
</Layout>

<style>
.heat-map {
    margin-top: 1em;

    & > .container {
        z-index: 2;
        aspect-ratio: 1;
        position: relative;
        background-color: #ffffffaa;
        overflow: hidden;
    }

    & > p {
        text-align: center;
        padding: 1em;
        padding-bottom: 0;
        color: var(--muted-foreground);
    }
}

.location {
    z-index: 3;
    position: absolute;

    .icon {
        display: flex;
        justify-content: center; 
        align-items: center;
        --icon-size: 32px;
        width: var(--icon-size);
        height: var(--icon-size);
        margin: 0 auto 4px auto;
    }

    p {
        text-align: center;
        margin: 0;
        font-size: x-small;
        color: var(--muted-foreground);
    }

    div {
        background-color: white;
        border-radius: 100vw;
    }

    .info {
        padding: 0.2em 1em;
    }

    .bg {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: -1;

        filter: blur(24px);
        opacity: 0.7;


        --size-bg: 5em;
        height: var(--size-bg);
        width: var(--size-bg);

        background-color: oklch(0.905 0.093 164.15);
    }

    &:nth-child(2) .bg {
        background-color: oklch(91.729% 0.06498 94.978);
    }
    &:nth-child(3) .bg {
        background-color: oklch(0.941 0.03 12.58);
    }
    &:nth-child(4) .bg {
        background-color: oklch(0.93 0.034 272.788);
    }
    &:nth-child(5) .bg {
        background-color: oklch(0.943 0.029 294.588);
    }
}

.notice {
    margin-top: 1em;
}

</style>