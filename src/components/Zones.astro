---

interface Props {
  name: string;
  icon: string;
  mood: string;
  need: string;
  size: number;
}
const { name, icon, mood, size, need } = Astro.props;
const lowercaseMood = mood.toLowerCase();
---

<div class="container">
    <div class="same-line">
        <div>
            <h3>{name}</h3>
            <p class="mood-body">Most common mood: <span class={"status-tag pill mood " + lowercaseMood}>{mood}</span></p>
        </div>
        <span class="icon">{icon}</span>
    </div>
    <p>
        <span class="status-tag pill check-in">{size} check-ins</span>
        <span class="status-tag pill need">Top need: {need}</span>
    </p>
</div>

<style>
h3 {
    display: inline-block;
    font-size: medium;
}

.container {
    padding-top: 14px;
    margin-top: 1em;
}

.icon {
    margin-left: auto;
    font-size: x-large;
}

.mood-body {
    color: var(--muted-foreground);
}

.same-line {
    margin-bottom: 8px;
}

.check-in { 
    color: color-mix(in oklab, var(--secondary) 50%, black);
    background-color: color-mix(in oklab, var(--secondary) 80%, white)
}

.need {
    color: var(--primary);
    background-color: color-mix(in oklab, var(--primary) 10%, white);
}
</style>
