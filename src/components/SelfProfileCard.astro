---
const { name, course } = Astro.props;
---

<div class="profile card">
    <div class="profile-header">
        <div class="profile-avatar">🦦</div>
        <div class="profile-info">
            <h2>{ name }</h2>
            <p>{ course }</p>
        </div>
    </div>
</div>

<style>
.profile {
    background: linear-gradient(to right bottom, oklch(0.943 0.029 294.588) 0%, oklch(0.951 0.026 236.824) 50%, oklch(0.95 0.052 163.051) 100%);
}
</style>
